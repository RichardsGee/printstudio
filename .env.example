# =============================================================================
# PrintStudio — Environment Variables (root reference)
# =============================================================================
# Cada app (bridge, api, web) tem seu próprio .env.example com subset dessas.
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite .env — apenas .env.example.
# =============================================================================

# -----------------------------------------------------------------------------
# GLOBAL
# -----------------------------------------------------------------------------
NODE_ENV=development                    # development | production
LOG_LEVEL=info                          # debug | info | warn | error

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL no EasyPanel)
# -----------------------------------------------------------------------------
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Dev local: rode um postgres via docker ou use o do EasyPanel externamente.
# Prod: URL interna do service no EasyPanel (ex: postgres://user:pass@printstudio_postgres:5432/printstudio)
DATABASE_URL=postgresql://printstudio:CHANGE_ME@localhost:5432/printstudio

# Pool config (opcional)
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# -----------------------------------------------------------------------------
# AUTH (Auth.js / NextAuth v5)
# -----------------------------------------------------------------------------
# Gere com: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_openssl_rand_base64_32
AUTH_URL=http://localhost:3000         # Prod: https://printstudio.seudominio.com

# -----------------------------------------------------------------------------
# BRIDGE AGENT (roda no seu PC local)
# -----------------------------------------------------------------------------
BRIDGE_PORT=8080                        # Porta HTTP/WS do bridge local
BRIDGE_MDNS_NAME=printstudio.local      # Nome mDNS pro dual-mode detection

# Cloud endpoint pra bridge conectar (outbound WebSocket)
# Em prod: URL pública do API no EasyPanel
CLOUD_WS_URL=ws://localhost:4000/ws/bridge
CLOUD_API_TOKEN=CHANGE_ME_bridge_auth_token   # Token pro bridge autenticar na cloud

# -----------------------------------------------------------------------------
# IMPRESSORAS BAMBU LAB A1 (credenciais LAN mode)
# -----------------------------------------------------------------------------
# Pega no display da impressora: Settings > WLAN > IP address / Access code
# Também rola cadastrar via UI depois, isso aqui é só fallback/seed.

PRINTER_1_NAME=A1 #1
PRINTER_1_SERIAL=CHANGE_ME              # Serial da Bambu (ex: 00M00A3B0000001)
PRINTER_1_IP=192.168.1.101
PRINTER_1_ACCESS_CODE=CHANGE_ME         # 8 dígitos exibidos no painel

PRINTER_2_NAME=A1 #2
PRINTER_2_SERIAL=CHANGE_ME
PRINTER_2_IP=192.168.1.102
PRINTER_2_ACCESS_CODE=CHANGE_ME

PRINTER_3_NAME=A1 #3
PRINTER_3_SERIAL=CHANGE_ME
PRINTER_3_IP=192.168.1.103
PRINTER_3_ACCESS_CODE=CHANGE_ME

# -----------------------------------------------------------------------------
# CÂMERA (go2rtc)
# -----------------------------------------------------------------------------
GO2RTC_PORT=1984                        # Porta do go2rtc
GO2RTC_CONFIG_PATH=./go2rtc.yaml

# -----------------------------------------------------------------------------
# API (EasyPanel)
# -----------------------------------------------------------------------------
API_PORT=4000
API_CORS_ORIGIN=http://localhost:3000   # Prod: URL do PWA
API_PUBLIC_URL=http://localhost:4000    # URL pública (usada em webhooks, etc)

# -----------------------------------------------------------------------------
# WEB / PWA (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000          # API cloud
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws/client   # WebSocket cloud
NEXT_PUBLIC_LAN_DISCOVERY_HOST=printstudio.local   # Detecção LAN
NEXT_PUBLIC_LAN_DISCOVERY_PORT=8080
NEXT_PUBLIC_APP_NAME=PrintStudio

# -----------------------------------------------------------------------------
# NOTIFICAÇÕES (n8n — decidir canal no v1.1)
# -----------------------------------------------------------------------------
# Webhook do n8n que roteia pra Telegram/WhatsApp/Email
N8N_WEBHOOK_URL=                        # ex: https://n8n.seuservidor.com/webhook/printstudio
N8N_WEBHOOK_TOKEN=                      # Token opcional pra autenticar

# -----------------------------------------------------------------------------
# STORAGE (MinIO - só no v2 pra uploads .3mf)
# -----------------------------------------------------------------------------
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=printstudio
