{
  "name": "printstudio",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma de gestão para Bambu Lab A1",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter './apps/*' run dev",
    "dev:bridge": "pnpm --filter @printstudio/bridge dev",
    "dev:api": "pnpm --filter @printstudio/api dev",
    "dev:web": "pnpm --filter @printstudio/web dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "db:generate": "pnpm --filter @printstudio/db run generate",
    "db:migrate": "pnpm --filter @printstudio/db run migrate",
    "db:studio": "pnpm --filter @printstudio/db run studio",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
