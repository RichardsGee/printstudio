{
  "name": "@printstudio/bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PrintStudio local bridge agent — MQTT to Bambu printers, outbound WS to cloud, inbound WS/HTTP to LAN clients",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint yet'"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/websocket": "^11.0.1",
    "@printstudio/bambu-protocol": "workspace:*",
    "@printstudio/shared": "workspace:*",
    "adm-zip": "^0.5.17",
    "basic-ftp": "^5.3.0",
    "better-sqlite3": "^11.5.0",
    "bonjour-service": "^1.3.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "mqtt": "^5.10.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "sharp": "^0.34.5",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
