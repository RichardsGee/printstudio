# =============================================================================
# PrintStudio Bridge — Environment Variables
# =============================================================================
# Copy to .env and fill values. NEVER commit .env.
# =============================================================================

NODE_ENV=development
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# BRIDGE SERVER
# -----------------------------------------------------------------------------
BRIDGE_PORT=8080
BRIDGE_MDNS_NAME=printstudio.local
BRIDGE_ID=bridge-local-01

# SQLite local database path (relative to apps/bridge)
BRIDGE_DB_PATH=./data/bridge.db

# -----------------------------------------------------------------------------
# CLOUD WS (outbound)
# -----------------------------------------------------------------------------
CLOUD_WS_URL=ws://localhost:4000/ws/bridge
CLOUD_API_TOKEN=CHANGE_ME_bridge_auth_token

# -----------------------------------------------------------------------------
# PRINTERS (LAN mode credentials)
# -----------------------------------------------------------------------------
# Each PRINTER_N block needs SERIAL + IP + ACCESS_CODE, NAME is optional.
# ID is generated from SERIAL if omitted; set explicitly to persist across runs.

PRINTER_1_ID=
PRINTER_1_NAME=A1 #1
PRINTER_1_SERIAL=CHANGE_ME
PRINTER_1_IP=192.168.1.101
PRINTER_1_ACCESS_CODE=CHANGE_ME

PRINTER_2_ID=
PRINTER_2_NAME=A1 #2
PRINTER_2_SERIAL=CHANGE_ME
PRINTER_2_IP=192.168.1.102
PRINTER_2_ACCESS_CODE=CHANGE_ME

PRINTER_3_ID=
PRINTER_3_NAME=A1 #3
PRINTER_3_SERIAL=CHANGE_ME
PRINTER_3_IP=192.168.1.103
PRINTER_3_ACCESS_CODE=CHANGE_ME
