# =============================================================================
# PrintStudio API — Environment Variables
# =============================================================================
# Copie para .env (ou configure no painel do EasyPanel).
# Nunca commite .env.
# =============================================================================

NODE_ENV=development                    # development | production
LOG_LEVEL=info                          # debug | info | warn | error

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
# Em prod: URL interna do service no EasyPanel
DATABASE_URL=postgresql://printstudio:CHANGE_ME@localhost:5432/printstudio

# -----------------------------------------------------------------------------
# AUTH (Auth.js-compatible sessions)
# -----------------------------------------------------------------------------
# Gere com: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_PORT=4000
API_CORS_ORIGIN=http://localhost:3000   # URL do PWA (single origin MVP)

# -----------------------------------------------------------------------------
# BRIDGE AUTH
# -----------------------------------------------------------------------------
# Token compartilhado pro bridge autenticar via bridge.hello.
# MVP: um bridge por deployment. Gere com: openssl rand -hex 32
CLOUD_API_TOKEN=CHANGE_ME_bridge_auth_token

# -----------------------------------------------------------------------------
# NOTIFICAÇÕES (opcional) — alertas via Telegram pra eventos críticos
# -----------------------------------------------------------------------------
# 1. No Telegram, conversar com @BotFather → /newbot → anotar o token
# 2. Conversar com seu bot pelo menos uma vez pra habilitar
# 3. Pegar seu chat_id via @userinfobot
# Deixe em branco pra desabilitar notificações.
# TELEGRAM_BOT_TOKEN=12345:ABC-DEF_xyz
# TELEGRAM_CHAT_ID=123456789
