# =============================================================================
# PrintStudio Web (Next.js PWA)
# =============================================================================
NODE_ENV=development

# Database (server-side auth via @printstudio/db)
DATABASE_URL=postgresql://printstudio:CHANGE_ME@localhost:5432/printstudio

# Auth.js v5
AUTH_SECRET=CHANGE_ME_openssl_rand_base64_32
AUTH_URL=http://localhost:3000

# Cloud API (fallback in dual-mode)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws/client

# LAN bridge (preferred in dual-mode)
NEXT_PUBLIC_LAN_DISCOVERY_HOST=printstudio.local
NEXT_PUBLIC_LAN_DISCOVERY_PORT=8080

NEXT_PUBLIC_APP_NAME=PrintStudio
